# GatePassX — Environment Configuration
#
# Copy this file to .env and adjust values for your environment.

# QR payload integrity secret (HMAC-SHA256).
# MUST be set to the same value across Python generator AND mobile app builds.
# Leave unset to use the insecure dev default (NOT for production).
AHUON_QR_SECRET=your-production-secret-here

# Android release signing (see mobile/android/signing.gradle)
# ANDROID_KEYSTORE_PATH=/path/to/keystore.jks
# ANDROID_KEYSTORE_PASSWORD=changeit
# ANDROID_KEY_ALIAS=upload
# ANDROID_KEY_PASSWORD=changeit
